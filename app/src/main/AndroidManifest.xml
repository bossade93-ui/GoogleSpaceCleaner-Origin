<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions minimales : aucune permission de stockage large,
         tout passe par les API Google (OAuth) et le Photos Picker,
         qui ne nécessitent pas de permission système de fichiers. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".GsApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GoogleSpaceCleaner">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GoogleSpaceCleaner">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GsApplication implémente Configuration.Provider pour injecter
             HiltWorkerFactory (voir DriveScanWorker) : l'auto-initialisation
             par défaut de WorkManager (via App Startup) doit donc être
             désactivée ici, sinon WorkManager s'initialise deux fois et
             Android Lint bloque le build (RemoveWorkManagerInitializer). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
